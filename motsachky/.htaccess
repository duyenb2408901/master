# Bật bộ điều hướng sạch RewriteEngine
RewriteEngine On

# Chống tấn công duyệt thư mục trái phép (Bảo mật nâng cao)
Options -Indexes

# Thiết lập HTTP Caching cho tài nguyên tĩnh ngay trên máy chủ Apache (Tiêu chí 5 & 6)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
</IfModule>